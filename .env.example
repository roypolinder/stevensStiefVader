APP_NAME=Laracord
APP_ENV=development
LOG_CHANNEL=stack
LOG_LEVEL=debug

DISCORD_TOKEN=
DISCORD_GUILD_ID=
OPENAI_API_KEY=

AI_VOICE_CHAT_MODEL=gpt-4.1-mini
AI_VOICE_TTS_MODEL=gpt-4o-mini-tts
AI_VOICE_TTS_VOICE=alloy
AI_VOICE_TEMPERATURE=0.8
AI_VOICE_MAX_OUTPUT_TOKENS=120
AI_VOICE_MAX_TTS_CHARS=300

# Node.js voice sidecar
VOICE_SIDECAR_URL=http://127.0.0.1:3001
VOICE_SIDECAR_TOKEN=change_me_to_a_random_secret

